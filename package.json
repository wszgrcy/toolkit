{
  "name": "cyia-template",
  "version": "1.5.3",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "repository": {
    "url": "https://github.com/wszgrcy/toolkit"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "rimraf ./test-dist && tsx ./script/test.esbuild.ts && mocha \"./test-dist/**/*.spec.mjs\" --enable-source-maps --inspect",
    "build": "rimraf ./dist && tsx ./script/build.esbuild.ts && tsc -P ./tsconfig.type.json ",
    "coverage": "c8 npm run test",
    "lint": "eslint --fix ./packages/**/*.ts && prettier ./packages/**/*.ts --write",
    "publish-only": "tsx ./script/publish.ts"
  },
  "author": "",
  "license": "MIT",
  "description": "External call utility for managing external processes and downloads",
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/chai": "^5.2.3",
    "@types/is-relative": "^1.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.11",
    "@types/normalize-path": "^3.0.2",
    "@types/semver": "^7.7.0",
    "@types/yazl": "^3.3.1",
    "c8": "^10.1.3",
    "chai": "^6.2.2",
    "esbuild": "^0.25.4",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^10.2.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "fast-glob": "^3.3.3",
    "globals": "^16.0.0",
    "mocha": "^11.2.2",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.32.0",
    "uuid": "^13.0.0"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.45.1",
    "execa": "^9.6.1",
    "extract-zip": "^2.0.1",
    "fastq": "^1.20.1",
    "file-type": "^22.0.1",
    "ipull": "3.9.3",
    "is-relative": "^1.0.0",
    "jsonc-parser": "^3.3.1",
    "magic-string": "^0.30.21",
    "marked": "^18.0.2",
    "normalize-path": "^3.0.0",
    "rfdc": "^1.4.1",
    "rxjs": "^7.8.2",
    "semver": "^7.7.4",
    "static-injector": ">=6.1.2",
    "tar": "^7.5.13",
    "valibot": "^1.1.0",
    "yaml": "^2.8.3",
    "yazl": "^3.3.1",
    "yauzl": "^3.3.0"
  }
}
